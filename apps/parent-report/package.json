{
  "name": "@jingshi/parent-report",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "项目2 · 家长报告：基于学生收费计算，为每位家长生成 PPT/PDF。下游，依赖 billing-core。",
  "dependencies": {
    "@jingshi/billing-core": "*",
    "pdf-lib": "^1.17.1",
    "playwright-core": "^1.59.1"
  },
  "scripts": {
    "build:teachers": "node scripts/build-teachers.mjs",
    "build:teacher-score-averages": "node scripts/build-teacher-score-averages.mjs",
    "update:template-faculty": "node scripts/update-template-faculty.mjs",
    "build:faculty": "node scripts/build-teachers.mjs && node scripts/update-template-faculty.mjs",
    "generate": "cd ../.. && node apps/parent-report/src/generate-parent-report.mjs",
    "generate:codex": "cd ../.. && node apps/parent-report/src/generate-codex-parent-report.mjs",
    "generate:student-billing": "npm run build:teachers && cd ../.. && node apps/parent-report/src/generate-student-billing-reports.mjs",
    "generate:student-billing-pdf": "npm run generate:student-billing && npm run export:student-billing-pdf",
    "export:pdf": "cd ../.. && node apps/parent-report/src/export-parent-report-pdf.mjs",
    "export:student-billing-pdf": "cd ../.. && node apps/parent-report/src/export-student-billing-pdfs.mjs",
    "export:web-pdf": "cd ../.. && node apps/parent-report/src/export-web-pdf.mjs",
    "test": "cd ../.. && node --test apps/parent-report/tests/*.test.mjs"
  }
}
